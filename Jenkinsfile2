pipeline {
  agent any 
  stages {
    stage ('Clone Code') {
      steps{
        checkout scm
      }
    }
    stage ('Build Docker Image') {
      steps{
        bat 'docker build -t devops-day13-app .'
      }
    }
    stage('Test Container') {
      steps {
        bat 'docker run -d -p 8081:80 devops-day13-app'
      }
    }
    stage('Verify Running Container') {
      steps {
        bat 'docker ps'
      }
    }
  }
}
